#!/bin/bash

echo "⚡ CodeReview.AI — analyzing your code..."

DIFF=$(git diff --cached)

if [ -z "$DIFF" ]; then
  echo "No staged changes found. Skipping review."
  exit 0
fi

cd "$(git rev-parse --show-toplevel)"
source venv/bin/activate

python3 - <<'EOF'
from review import review_code
import json, sys, subprocess

diff = subprocess.run(['git', 'diff', '--cached'], capture_output=True, text=True).stdout

result = review_code(diff)
clean = result.replace('```json', '').replace('```', '').strip()
data = json.loads(clean)

bugs = len(data['bugs'])
security = len(data['security'])

if data['bugs']:
    print('\n🐛 BUGS FOUND:')
    for b in data['bugs']:
        print(f'  • {b}')

if data['security']:
    print('\n🔐 SECURITY ISSUES:')
    for s in data['security']:
        print(f'  • {s}')

if data['improvements']:
    print('\n✨ IMPROVEMENTS:')
    for i in data['improvements']:
        print(f'  • {i}')

with open('/tmp/cr_security_count', 'w') as f:
    f.write(str(security))
EOF

SECURITY_COUNT=$(cat /tmp/cr_security_count 2>/dev/null || echo "0")

if [ "$SECURITY_COUNT" -gt "0" ]; then
  echo ""
  echo "❌ COMMIT BLOCKED — $SECURITY_COUNT security issue(s) found."
  echo "   Fix the issues above before committing."
  exit 1
fi

echo ""
echo "✅ Review passed. Committing..."
exit 0